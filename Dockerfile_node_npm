# syntax=docker/dockerfile:1.7

ARG UBUNTU_BASE=ubuntu:24.04
ARG STRAPI_VERSION=5.38.0
ARG NODE_MAJOR=24
# Pin npm to a known version (set to latest you want). Example shown:
ARG NPM_VERSION=11.11.0

# -------------------------
# Stage 1: builder
# -------------------------
FROM ${UBUNTU_BASE} AS builder

ARG STRAPI_VERSION
ARG NODE_MAJOR
ARG NPM_VERSION

ENV DEBIAN_FRONTEND=noninteractive

# Patch OS packages + install build deps
RUN apt-get update \
 && apt-get upgrade -y \
 && apt-get install -y --no-install-recommends \
      ca-certificates curl gnupg \
      python3 make g++ build-essential \
      libvips-dev \
 && rm -rf /var/lib/apt/lists/*

# Install Node.js from NodeSource
RUN mkdir -p /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/*

# Upgrade npm (patch npm CVEs / bugs)
RUN npm install -g npm@${NPM_VERSION} --no-audit --no-fund \
 && npm --version

# Make npm network behavior more reliable (optional but helpful)
RUN npm config set registry https://registry.npmjs.org/ \
 && npm config set audit false \
 && npm config set fund false \
 && npm config set fetch-retries 5 \
 && npm config set fetch-retry-mintimeout 20000 \
 && npm config set fetch-retry-maxtimeout 120000 \
 && npm config set fetch-timeout 300000 \
 && npm config set maxsockets 10

# Install Strapi CLI pinned (omit dev deps)
RUN --mount=type=cache,target=/root/.npm \
    npm install -g @strapi/strapi@${STRAPI_VERSION} --omit=dev --no-audit --no-fund

# -------------------------
# Stage 2: runtime
# -------------------------
FROM ${UBUNTU_BASE} AS runtime

ARG STRAPI_VERSION
ARG NODE_MAJOR
ARG NPM_VERSION

ENV DEBIAN_FRONTEND=noninteractive \
    NODE_ENV=production \
    STRAPI_VERSION=${STRAPI_VERSION}

# Patch OS packages + install minimal runtime deps
RUN apt-get update \
 && apt-get upgrade -y \
 && apt-get install -y --no-install-recommends \
      ca-certificates curl gnupg \
      tini \
      libvips \
 && rm -rf /var/lib/apt/lists/*

# Install Node.js runtime
RUN mkdir -p /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/*

# Upgrade npm in runtime too (so the shipped image has patched npm)
RUN npm install -g npm@${NPM_VERSION} --no-audit --no-fund \
 && npm --version

# Enable corepack (optional)
RUN corepack enable

# Copy Strapi CLI from builder
# On Ubuntu + NodeSource, globals typically live here:
COPY --from=builder /usr/lib/node_modules /usr/lib/node_modules
COPY --from=builder /usr/bin/strapi /usr/bin/strapi

# Non-root user + app dir
RUN useradd -m -u 10001 -s /bin/bash strapi \
 && mkdir -p /srv/app \
 && chown -R strapi:strapi /srv/app

WORKDIR /srv/app
USER strapi

EXPOSE 1337

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["strapi", "--help"]
